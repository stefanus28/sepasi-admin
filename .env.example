# ============================================================
# SEPASI ADMIN — Environment Variables
# Salin file ini menjadi .env.local lalu isi semua value
# JANGAN pernah commit .env.local ke GitHub
# ============================================================

# Database MySQL (Prisma)
DATABASE_URL="mysql://user:password@host:3306/database_name"

# Secret key enkripsi password (WAJIB tepat 32 karakter)
SECRET_KEY="12345678901234567890123456789012"

# Secret key iron-session (WAJIB minimal 32 karakter)
SESSION_PASSWORD="sepasi-admin-session-secret-key-minimum-32-chars"

# URL ecommerce app (untuk CORS whitelist)
# Dev: http://localhost:3001 | Prod: https://sepasi-ecommerce.vercel.app
ECOMMERCE_URL="http://localhost:3001"

# Credentials untuk script create-admin (hanya dipakai saat setup awal)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="ganti_dengan_password_kuat"
